{
    "name": "104 PTT 工作評論",
    "description": "pudding design",
    "version": "1.1.6",
    "manifest_version": 3,
    "host_permissions": [
        "https://*/"
    ],
    "permissions": [
        "scripting",
        "activeTab",
        "tabs"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.104.com.tw/*"
            ],
            "css": [
                "job.css"
            ],
            "js": [
                "job.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "popup.html",
                "popup.css",
                "popup.js",
                "three-party/*",
                "three-party/css/*",
                "three-party/fontawesome/css/*",
                "three-party/fontawesome/webfonts/*",
                "three-party/js/*"
            ],
            "matches": [
                "https://www.104.com.tw/*"
            ]
        }
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    }
}